        .suggestion-container .suggestion-content .alert {
            margin: 0;
            padding: 7px 9px;
            border-radius: 7px;
            border-left-width: 3px;
            line-height: 1.45;
            width: 100%;
            max-width: none;
            box-sizing: border-box;
        }

        .suggestion-container .suggestion-content .query-item {
            margin: 0;
            border-radius: 7px;
            border-left-width: 3px;
        }

        .suggestion-container .suggestion-content .query-item pre,
        .suggestion-container .suggestion-content .query-item pre[class*="language-"] {

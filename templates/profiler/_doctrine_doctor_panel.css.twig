        code[class*="language-"],
        pre[class*="language-"] {
            background: none;
            text-shadow: none;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            font-size: 13px;
            line-height: 1.6;
            white-space: pre-wrap;
            word-break: break-word;
        }

        pre[class*="language-"] {

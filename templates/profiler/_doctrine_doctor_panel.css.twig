            color: #8b7f74 !important;
        }

        .theme-dark .dd-panel-typography pre.line-numbers .line-numbers-rows {
            border-right-color: #3d4753 !important;
            background: rgba(255, 255, 255, 0.03);
        }

        .theme-dark .dd-panel-typography pre.line-numbers .line-numbers-rows > span:before {
            color: #76879b !important;
        }

        /* Fallback when Prism line-number stylesheet is unavailable/blocked.
           Supports both DOM shapes:
           - <pre class="line-numbers"><code>...</code><span class="line-numbers-rows">...</span></pre>
           - <pre class="line-numbers"><code>...<span class="line-numbers-rows">...</span></code></pre>
        */
        .dd-panel-typography pre.line-numbers {
            position: relative;
            padding-left: 3.4em !important;
            counter-reset: dd-linenumber;
        }

        .dd-panel-typography pre.line-numbers > code {
            position: relative;
            display: block;
        }

        .dd-panel-typography pre.line-numbers > .line-numbers-rows,
        .dd-panel-typography pre.line-numbers > code > .line-numbers-rows {
            position: absolute;
            pointer-events: none;
            top: 0;
            left: 0;
            width: 2.8em;
            user-select: none;
            border-right: 1px solid #d6c9ba;
            background: rgba(120, 95, 78, 0.05);
        }

        .dd-panel-typography pre.line-numbers > .line-numbers-rows > span,
        .dd-panel-typography pre.line-numbers > code > .line-numbers-rows > span {
            display: block;
            counter-increment: dd-linenumber;
            min-height: 1.5em;
            height: auto !important;
        }

        .dd-panel-typography pre.line-numbers > .line-numbers-rows > span:before,
        .dd-panel-typography pre.line-numbers > code > .line-numbers-rows > span:before {
            content: counter(dd-linenumber);
            display: block;
            padding-right: 0.8em;
            text-align: right;
            color: #8b7f74 !important;
            font-size: 11px;
            line-height: 1.5;
        }

        .theme-dark .dd-panel-typography pre.line-numbers > .line-numbers-rows,
        .theme-dark .dd-panel-typography pre.line-numbers > code > .line-numbers-rows {
            border-right-color: #3d4753;
            background: rgba(255, 255, 255, 0.03);
        }

        .theme-dark .dd-panel-typography pre.line-numbers > .line-numbers-rows > span:before,
        .theme-dark .dd-panel-typography pre.line-numbers > code > .line-numbers-rows > span:before {
            color: #76879b !important;
        }

        .dd-panel-typography pre.line-numbers.dd-ln-fallback > .line-numbers-rows > span:before,
        .dd-panel-typography pre.line-numbers.dd-ln-fallback > code > .line-numbers-rows > span:before {
            content: none !important;
        }

        .dd-panel-typography pre.line-numbers.dd-ln-fallback > .line-numbers-rows > span,

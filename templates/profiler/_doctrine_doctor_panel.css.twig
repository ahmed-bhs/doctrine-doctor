        /* ============================================
           Suggestion Layout Final Overrides
           ============================================ */
        .suggestion-container {
            margin-top: 10px;
        }

        .suggestion-container .suggestion-header {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            column-gap: 8px;
            padding: 4px 8px;
            min-height: 0;
            border-radius: 9px 9px 0 0;
        }

        .suggestion-container .suggestion-header::before {
            content: none;
        }

        .suggestion-container .suggestion-header h4 {
            margin: 0;
            min-width: 0;
            line-height: 1.15;
            font-size: 11px;
            letter-spacing: 0.1px;
        }

        .suggestion-container .dd-suggestion-actionability {
            align-self: center;
            margin: 0;
            padding: 1px 6px;
            font-size: 9px;
            letter-spacing: 0.25px;
        }

        .suggestion-container .suggestion-header.is-redundant-title {
            grid-template-columns: auto;
            justify-content: end;
            padding: 5px 8px;
            min-height: 0;
        }

        .suggestion-container .suggestion-header.is-redundant-title h4 {
            display: none;
        }

        .suggestion-container .suggestion-content {
            display: grid;
            gap: 8px;
            padding: 8px;
            border: 1px solid #ddd6ce;
            border-top: none;
            border-radius: 0 0 9px 9px;
            background: #fffdfa;
        }

        .suggestion-container .suggestion-content > * {
            margin: 0 !important;
        }

        .suggestion-container .suggestion-content > .dd-suggestion-meta-intro {
            padding: 7px 9px;
            border-left-width: 3px;
            border-radius: 7px;
            width: 100%;
            max-width: none;
            box-sizing: border-box;
        }

        .suggestion-container .suggestion-content > .dd-suggestion-meta-file {
            margin-top: -4px !important;
            padding: 6px 9px 7px;
            border-left-width: 3px;
            border-radius: 0 0 7px 7px;
            width: 100%;
            max-width: none;
            box-sizing: border-box;
        }

        .suggestion-container .dd-suggestion-step {
            display: grid;
            gap: 6px;
            margin: 0;
            padding: 8px 9px;
            border-radius: 8px;
            border: 1px solid #ddd8d2;
            border-left: 3px solid #9a6d4d;
            background: #fffcf8;
        }

        .suggestion-container .dd-suggestion-step > * {

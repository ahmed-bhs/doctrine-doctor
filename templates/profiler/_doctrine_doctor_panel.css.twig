        .dd-panel-typography .dd-btn,
        .dd-panel-typography .dd-issue-search,
        .dd-panel-typography .dd-issue-sort,
        .dd-panel-typography .suggestion-content code,
        .dd-panel-typography .suggestion-content .doc-link,

        /* ============================================
           Typography System
           ============================================ */
        .dd-panel-typography {
            --dd-fs-xs: 11px;
            --dd-fs-sm: 12px;
            --dd-fs-md: 13px;
            --dd-fs-lg: 14px;
            --dd-fs-xl: 16px;
            --dd-lh-tight: 1.35;
            --dd-lh-base: 1.5;
            --dd-lh-loose: 1.65;

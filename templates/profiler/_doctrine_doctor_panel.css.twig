        /* ============================================
           Duplicate Issues Panel
           ============================================ */

        .dd-duplicate-wrapper {
            position: relative;
            display: inline-block;
            margin-left: 8px;
        }

        .dd-duplicate-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 8px;
            background: linear-gradient(135deg, #E95420 0%, #772953 100%);
            color: white;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            vertical-align: middle;
            border: none;
        }

        .dd-duplicate-badge:hover {
            background: linear-gradient(135deg, #C34113 0%, #5E2750 100%);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(119, 41, 83, 0.3);
        }

        .dd-duplicate-badge svg {
            width: 14px;
            height: 14px;
            flex-shrink: 0;
        }

        .dd-duplicates-panel {
            margin-top: 12px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #fff;
            overflow: hidden;
        }

        .dd-duplicates-header {
            padding: 6px 12px;
            background: linear-gradient(135deg, #E95420 0%, #772953 100%);
            color: white;
            font-size: 13px;

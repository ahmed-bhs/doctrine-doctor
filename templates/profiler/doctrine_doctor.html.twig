{% extends request.isXmlHttpRequest ? '@WebProfiler/Profiler/ajax_layout.html.twig' : '@WebProfiler/Profiler/layout.html.twig' %}

{# Highlighting is now handled in PHP via DescriptionHighlighter utility class #}

{% macro render_issue(issue, loop_index, prefix) %}
    {% set severityKey = issue.getSeverity().isCritical() ? 'critical' : (issue.getSeverity().isWarning() ? 'warning' : 'info') %}
    <div
        class="issue-card"
        data-issue-card="true"
        data-severity="{{ severityKey }}"
        data-title="{{ issue.getTitle()|e('html_attr') }}"
        data-type="{{ issue.getType()|e('html_attr') }}"
    >
        <div class="issue-header">
            <div class="issue-header-content">
                <span class="issue-badge {% if issue.getSeverity().isCritical() %}badge-critical{% elseif issue.getSeverity().isWarning() %}badge-warning{% else %}badge-info{% endif %}">
                    {{ issue.getSeverity().getEmoji() }} {{ issue.getType() }}
                </span>
                <h3 class="issue-title">
                    {{ issue.getTitle() }}
                    {% if issue.getDuplicatedIssues()|length > 0 %}
                        <span class="dd-duplicate-wrapper">
                            <button
                                type="button"
                                class="dd-duplicate-badge dd-toggle"
                                data-toggle-selector="#{{ prefix }}-duplicates-{{ loop_index }}"
                                data-toggle-alt-content="Hide similar"
                                aria-controls="{{ prefix }}-duplicates-{{ loop_index }}"
                                aria-expanded="false"
                                title="Show similar issues"
                            >
                                <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                    <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286zm1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94z"/>
                                </svg>
                                <span class="dd-btn-text">{{ issue.getDuplicatedIssues()|length }} similar</span>
                                <svg class="dd-btn-chevron" width="12" height="12" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </button>
                        </span>
                    {% endif %}
                </h3>
            </div>
        </div>

        <div class="issue-body">
            <p class="issue-description">{{ issue.getDescription()|raw|nl2br }}</p>

            {# Action buttons container #}
            <div class="issue-actions">
                {% if issue.getSuggestion() %}
                    <button
                        type="button"
                        class="dd-btn dd-btn-primary dd-btn-sm dd-toggle dd-action-fix"
                        data-toggle-selector="#{{ prefix }}-suggestion-{{ loop_index }}"
                        data-toggle-alt-content="Hide fix"
                        aria-controls="{{ prefix }}-suggestion-{{ loop_index }}"
                        aria-expanded="false"
                    >
                        <svg class="dd-btn-icon" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                        </svg>
                        <span class="dd-btn-text">Fix</span>
                        <svg class="dd-btn-chevron" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </button>
                {% endif %}

                {% if issue.getQueries() %}
                    <button
                        type="button"
                        class="dd-btn dd-btn-secondary dd-btn-sm dd-toggle dd-action-queries"
                        data-toggle-selector="#{{ prefix }}-queries-{{ loop_index }}"
                        data-toggle-alt-content="Hide queries"
                        aria-controls="{{ prefix }}-queries-{{ loop_index }}"
                        aria-expanded="false"
                    >
                        <svg class="dd-btn-icon" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286zm1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94z"/>
                        </svg>
                        <span class="dd-btn-text">Queries</span>
                        <span class="dd-btn-badge">{{ issue.getQueries()|length }}</span>
                        <svg class="dd-btn-chevron" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </button>
                {% endif %}

                {% if issue.getBacktrace() %}
                    <button
                        type="button"
                        class="dd-btn dd-btn-secondary dd-btn-sm dd-toggle dd-action-trace"
                        data-toggle-selector="#{{ prefix }}-backtrace-{{ loop_index }}"
                        data-toggle-alt-content="Hide trace"
                        aria-controls="{{ prefix }}-backtrace-{{ loop_index }}"
                        aria-expanded="false"
                    >
                        <svg class="dd-btn-icon" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/>
                            <path d="M6.854 4.646a.5.5 0 0 1 0 .708L4.207 8l2.647 2.646a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 0 1 .708 0zm2.292 0a.5.5 0 0 0 0 .708L11.793 8l-2.647 2.646a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708 0z"/>
                        </svg>
                        <span class="dd-btn-text">Trace</span>
                        <svg class="dd-btn-chevron" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </button>
                {% endif %}
            </div>

            {% if issue.getDuplicatedIssues()|length > 0 %}
                <div id="{{ prefix }}-duplicates-{{ loop_index }}" class="dd-collapsible dd-duplicates-panel hidden">
                    <div class="dd-duplicates-header">
                        <strong>{{ issue.getDuplicatedIssues()|length }} related finding{{ issue.getDuplicatedIssues()|length > 1 ? 's' : '' }} (grouped for readability)</strong>
                    </div>
                    <div class="dd-duplicates-content">
                        {% for duplicatedIssue in issue.getDuplicatedIssues() %}
                            {% set duplicateBacktrace = duplicatedIssue.getBacktrace() %}
                            {% set firstFrame = duplicateBacktrace is iterable and duplicateBacktrace|length > 0 ? duplicateBacktrace|first : null %}
                            {% set frameFile = firstFrame is not null ? attribute(firstFrame, 'file')|default(null) : null %}
                            {% set frameLine = firstFrame is not null ? attribute(firstFrame, 'line')|default(null) : null %}
                            {% set duplicateData = duplicatedIssue.getData() %}
                            {% set precomputedTargetLabel = duplicateData.targetLabel|default(null) %}
                            {% set entityClass = duplicateData.entityClass|default(null) %}
                            {% set fieldName = duplicateData.fieldName|default(null) %}
                            {% set targetLabel = precomputedTargetLabel ?: (entityClass and fieldName ? entityClass ~ '::' ~ fieldName|replace({'$': ''}) : (entityClass ?: (fieldName ? fieldName|replace({'$': ''}) : null))) %}
                            {% set locationLabel = frameFile ? (frameLine ? frameFile ~ ':' ~ frameLine : frameFile) : null %}
                            {% set duplicateSignature = duplicatedIssue.getType() ~ '|' ~ duplicatedIssue.getTitle() ~ '|' ~ locationLabel ~ '|' ~ duplicatedIssue.getDescription() %}

                            <article
                                class="dd-duplicate-item"
                                data-severity="{% if duplicatedIssue.getSeverity().isCritical() %}critical{% elseif duplicatedIssue.getSeverity().isWarning() %}warning{% else %}info{% endif %}"
                                data-duplicate-signature="{{ duplicateSignature|e('html_attr') }}"
                            >
                                <div class="dd-duplicate-topline">
                                    <code class="dd-duplicate-type">{{ duplicatedIssue.getType() }}</code>
                                    {% if targetLabel %}
                                        <span class="dd-duplicate-location" title="{{ targetLabel }}">{{ targetLabel }}</span>
                                    {% elseif locationLabel %}
                                        <span class="dd-duplicate-location" title="{{ locationLabel }}">{{ locationLabel }}</span>
                                    {% endif %}
                                    {% if duplicatedIssue.getQueries()|length > 0 %}
                                        <span class="dd-duplicate-query-count">{{ duplicatedIssue.getQueries()|length }} quer{{ duplicatedIssue.getQueries()|length > 1 ? 'ies' : 'y' }}</span>
                                    {% endif %}
                                </div>
                                {% set dupDesc = duplicatedIssue.getDescription()|striptags|trim %}
                                {% if dupDesc %}
                                    <p class="dd-duplicate-description">{{ dupDesc }}</p>
                                {% endif %}
                            </article>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Collapsible content sections #}
            {% if issue.getQueries() %}
                <div id="{{ prefix }}-queries-{{ loop_index }}" class="dd-collapsible hidden">
                    <div class="queries-list">
                        {% for query in issue.getQueries() %}
                            <div class="query-item">
                                {{ query.sql|doctrine_format_sql(highlight = true)|raw }}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if issue.getSuggestion() %}
                <div id="{{ prefix }}-suggestion-{{ loop_index }}" class="dd-collapsible suggestion-container hidden">
                    {% set suggestionCode = issue.getSuggestion().getCode() %}
                    {% if '<div' in suggestionCode or '<p' in suggestionCode or '<ul' in suggestionCode or '<h' in suggestionCode or '<table' in suggestionCode %}
                        {{ suggestionCode|raw }}
                    {% else %}
                        <div class="suggestion-header">
                            <h4>Suggested fix</h4>
                        </div>
                        <div class="suggestion-content">
                            <div class="query-item">
                                <pre><code class="language-php">{{ suggestionCode }}</code></pre>
                            </div>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {% if issue.getBacktrace() %}
                <div id="{{ prefix }}-backtrace-{{ loop_index }}" class="dd-collapsible hidden">
                    <div class="backtrace-content">
                        <pre>{{ issue.getBacktrace()|json_encode(constant('JSON_PRETTY_PRINT'))|raw }}</pre>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endmacro %}

{% block toolbar %}
    {% if collector.getStats.total_issues > 0 or collector.timelineQueries|length > 0 %}
        {% set icon %}
            {% set status = collector.getStats.critical > 0 ? 'red' : (collector.getStats.warning > 0 ? 'yellow' : '') %}

            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" class="sf-icon">
                <!-- Database (style tabler) -->
                <ellipse cx="8" cy="6" rx="6" ry="2.5" stroke-width="1.5"/>
                <path d="M 2 6 v 6 a 6 2.5 0 0 0 12 0 v -6" stroke-width="1.5"/>
                <path d="M 2 12 v 6 a 6 2.5 0 0 0 12 0 v -6" stroke-width="1.5"/>

                <!-- Warning signs in database -->
                <path d="M 6.5 9.5 L 7 8.5 L 7.5 9.5" stroke-width="0.9"/>
                <circle cx="7" cy="10" r="0.3" fill="currentColor"/>
                <path d="M 9 15 L 9.5 14 L 10 15" stroke-width="0.9"/>
                <circle cx="9.5" cy="15.5" r="0.3" fill="currentColor"/>

                <!-- Magnifying glass 🔍 style -->
                <circle cx="16.5" cy="9.5" r="4" stroke-width="1.5"/>

                <!-- Scan lines - analysis effect (thinner) -->
                <line x1="12.5" y1="7" x2="16" y2="7" stroke="currentColor" stroke-width="1.2" opacity="0.8"/>
                <line x1="12" y1="9.5" x2="16.5" y2="9.5" stroke="currentColor" stroke-width="1.5" opacity="0.9"/>
                <line x1="12.5" y1="12" x2="16" y2="12" stroke="currentColor" stroke-width="1.2" opacity="0.8"/>

                <!-- Handle with perspective - same length but better angle -->
                <path d="M 19.7 12.7 L 20 13 L 23.5 17 Q 24 17.8 23.5 18.5 Q 23 19.2 22.2 18.8 L 21.5 18 L 19.5 12.5 Z" fill="currentColor" opacity="0.15"/>
                <path d="M 19.8 12.8 L 20.1 13.1 L 23.2 16.5 Q 23.6 17.1 23.2 17.7 Q 22.8 18.3 22.3 18 L 21.7 17.3 L 19.6 12.6 Z" fill="currentColor"/>
            </svg>
            <span class="sf-toolbar-value">{{ collector.getStats.total_issues }}</span>
        {% endset %}

        {% set text %}
            <div class="sf-toolbar-info-piece">
                <b>Total Issues</b>
                <span class="sf-toolbar-status {{ collector.getStats.total_issues > 0 ? 'sf-toolbar-status-yellow' : '' }}">{{ collector.getStats.total_issues }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Critical Issues</b>
                <span class="sf-toolbar-status {{ collector.getStats.critical > 0 ? 'sf-toolbar-status-red' : '' }}">{{ collector.getStats.critical }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Warnings</b>
                <span class="sf-toolbar-status {{ collector.getStats.warning > 0 ? 'sf-toolbar-status-yellow' : '' }}">{{ collector.getStats.warning }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Info</b>
                <span>{{ collector.getStats.info }}</span>
            </div>
            <div class="sf-toolbar-info-piece">
                <b>Queries Analyzed</b>
                <span>{{ collector.timelineQueries|length }}</span>
            </div>
        {% endset %}

        {{ include('@WebProfiler/Profiler/toolbar_item.html.twig', { link: profiler_url, status: status|default('') }) }}
    {% endif %}
{% endblock %}

{% block menu %}
    <span class="label {{ collector.getStats.critical > 0 ? 'label-status-error' : (collector.getStats.warning > 0 ? 'label-status-warning' : '') }} {{ collector.getStats.total_issues == 0 and collector.timelineQueries|length == 0 ? 'disabled' }}">
        <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <!-- Database (style tabler) -->
                <ellipse cx="8" cy="6" rx="6" ry="2.5" stroke-width="1.5"/>
                <path d="M 2 6 v 6 a 6 2.5 0 0 0 12 0 v -6" stroke-width="1.5"/>
                <path d="M 2 12 v 6 a 6 2.5 0 0 0 12 0 v -6" stroke-width="1.5"/>

                <!-- Warning signs in database -->
                <path d="M 6.5 9.5 L 7 8.5 L 7.5 9.5" stroke-width="0.9"/>
                <circle cx="7" cy="10" r="0.3" fill="currentColor"/>
                <path d="M 9 15 L 9.5 14 L 10 15" stroke-width="0.9"/>
                <circle cx="9.5" cy="15.5" r="0.3" fill="currentColor"/>

                <!-- Magnifying glass 🔍 style -->
                <circle cx="16.5" cy="9.5" r="4" stroke-width="1.5"/>

                <!-- Scan lines - analysis effect (thinner) -->
                <line x1="12.5" y1="7" x2="16" y2="7" stroke="currentColor" stroke-width="1.2" opacity="0.8"/>
                <line x1="12" y1="9.5" x2="16.5" y2="9.5" stroke="currentColor" stroke-width="1.5" opacity="0.9"/>
                <line x1="12.5" y1="12" x2="16" y2="12" stroke="currentColor" stroke-width="1.2" opacity="0.8"/>

                <!-- Handle with perspective - same length but better angle -->
                <path d="M 19.7 12.7 L 20 13 L 23.5 17 Q 24 17.8 23.5 18.5 Q 23 19.2 22.2 18.8 L 21.5 18 L 19.5 12.5 Z" fill="currentColor" opacity="0.15"/>
                <path d="M 19.8 12.8 L 20.1 13.1 L 23.2 16.5 Q 23.6 17.1 23.2 17.7 Q 22.8 18.3 22.3 18 L 21.7 17.3 L 19.6 12.6 Z" fill="currentColor"/>
            </svg>
        </span>
        <strong>Doctrine Doctor</strong>
        {% if collector.getStats.total_issues > 0 %}
            <span class="count">
                <span>{{ collector.getStats.total_issues }}</span>
            </span>
        {% endif %}
    </span>
{% endblock %}

{% block panel %}
    <h2>Doctrine Doctor</h2>

    {% set dbInfo = collector.getDatabaseInfo %}

    {# Database + Analysis Metrics (single row) #}
    <div class="metrics">
        <div class="metric-group">
            <div class="metric">
                <span class="value">{{ dbInfo.driver }}</span>
                <span class="label">Database Engine</span>
            </div>

            <div class="metric">
                <span class="value">{{ dbInfo.database_version }}</span>
                <span class="label">Database Version</span>
            </div>

            <div class="metric">
                <span class="value {{ dbInfo.is_deprecated ? 'status-error' : '' }}">{{ dbInfo.doctrine_version }}</span>
                <span class="label">Doctrine ORM Version</span>
            </div>

            {% if dbInfo.is_deprecated %}
                <div class="metric">
                    <span class="value status-error">Deprecated</span>
                    <span class="label">Status</span>
                </div>
            {% endif %}
            <div class="metric">
                <span class="value {{ collector.getStats.critical > 0 ? 'status-error' : '' }}">{{ collector.getStats.critical }}</span>
                <span class="label">Critical</span>
            </div>

            <div class="metric">
                <span class="value {{ collector.getStats.warning > 0 ? 'status-warning' : '' }}">{{ collector.getStats.warning }}</span>
                <span class="label">Warnings</span>
            </div>

            <div class="metric">
                <span class="value {{ collector.getStats.info > 0 ? 'status-info' : '' }}">{{ collector.getStats.info }}</span>
                <span class="label">Info</span>
            </div>

            <div class="metric">
                <span class="value status-info">{{ collector.timelineQueries|length }}</span>
                <span class="label">Queries Analyzed</span>
            </div>

            {% set overhead = collector.getProfilerOverhead %}
            {% if overhead.total_time_ms > 0 %}
                <div class="metric">
                    <span class="value dd-overhead-value" title="Time spent by Doctrine Doctor analysis (excluded from app performance)">{{ overhead.total_time_ms|number_format(2) }} ms</span>
                    <span class="label">Profiler Overhead</span>
                </div>
            {% endif %}
        </div>
    </div>

    {% if dbInfo.is_deprecated %}
        <div class="dd-alert dd-alert-error dd-mb-20">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
            </svg>
            <div>
                <strong>Deprecated Version Detected</strong>
                <p class="dd-alert-deprecation-message">{{ dbInfo.deprecation_message }}</p>
            </div>
        </div>
    {% endif %}

    <div class="sf-tabs dd-panel-typography">
        <div class="tab {{ collector.getIssueCountByCategory('performance') == 0 ? 'disabled' }}">
            <h3 class="tab-title">⚡ Performance ({{ collector.getIssueCountByCategory('performance') }})</h3>
            <div class="tab-content">
                {% set performanceIssues = collector.getIssuesByCategory('performance') %}
                {% if performanceIssues is empty %}
                    <div class="empty">
                        <p>No performance issues detected.</p>
                    </div>
                {% else %}
                    {% import _self as macros %}
                    <div class="dd-issue-controls" data-controls-for="performance">
                        <div class="dd-control-group">
                            <input type="search" class="dd-issue-search" data-filter-search placeholder="Search title/type..." aria-label="Search performance issues">
                        </div>
                        <div class="dd-control-group dd-severity-filters" role="group" aria-label="Filter by severity">
                            <button type="button" class="dd-chip is-active" data-filter-severity="all">All</button>
                            <button type="button" class="dd-chip" data-filter-severity="critical">Critical</button>
                            <button type="button" class="dd-chip" data-filter-severity="warning">Warnings</button>
                            <button type="button" class="dd-chip" data-filter-severity="info">Info</button>
                        </div>
                        <div class="dd-control-group">
                            <select class="dd-issue-sort" data-filter-sort aria-label="Sort performance issues">
                                <option value="severity_desc">Sort: Severity</option>
                                <option value="title_asc">Title A-Z</option>
                                <option value="title_desc">Title Z-A</option>
                            </select>
                            <button type="button" class="dd-btn dd-btn-secondary dd-btn-sm" data-filter-reset>Reset</button>
                        </div>
                    </div>
                    <div class="dd-issue-list" data-issue-list="performance">
                        {% for issue in performanceIssues %}
                            {{ macros.render_issue(issue, loop.index, 'perf') }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tab {{ collector.getIssueCountByCategory('security') == 0 ? 'disabled' }}">
            <h3 class="tab-title">🛡️ Security ({{ collector.getIssueCountByCategory('security') }})</h3>
            <div class="tab-content">
                {% set securityIssues = collector.getIssuesByCategory('security') %}
                {% if securityIssues is empty %}
                    <div class="empty">
                        <p>No security issues detected.</p>
                    </div>
                {% else %}
                    {% import _self as macros %}
                    <div class="dd-issue-controls" data-controls-for="security">
                        <div class="dd-control-group">
                            <input type="search" class="dd-issue-search" data-filter-search placeholder="Search title/type..." aria-label="Search security issues">
                        </div>
                        <div class="dd-control-group dd-severity-filters" role="group" aria-label="Filter by severity">
                            <button type="button" class="dd-chip is-active" data-filter-severity="all">All</button>
                            <button type="button" class="dd-chip" data-filter-severity="critical">Critical</button>
                            <button type="button" class="dd-chip" data-filter-severity="warning">Warnings</button>
                            <button type="button" class="dd-chip" data-filter-severity="info">Info</button>
                        </div>
                        <div class="dd-control-group">
                            <select class="dd-issue-sort" data-filter-sort aria-label="Sort security issues">
                                <option value="severity_desc">Sort: Severity</option>
                                <option value="title_asc">Title A-Z</option>
                                <option value="title_desc">Title Z-A</option>
                            </select>
                            <button type="button" class="dd-btn dd-btn-secondary dd-btn-sm" data-filter-reset>Reset</button>
                        </div>
                    </div>
                    <div class="dd-issue-list" data-issue-list="security">
                        {% for issue in securityIssues %}
                            {{ macros.render_issue(issue, loop.index, 'security') }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tab {{ collector.getIssueCountByCategory('integrity') == 0 ? 'disabled' }}">
            <h3 class="tab-title">🧩 Integrity ({{ collector.getIssueCountByCategory('integrity') }})</h3>
            <div class="tab-content">
                {% set integrityIssues = collector.getIssuesByCategory('integrity') %}
                {% if integrityIssues is empty %}
                    <div class="empty">
                        <p>No integrity issues detected.</p>
                    </div>
                {% else %}
                    {% import _self as macros %}
                    <div class="dd-issue-controls" data-controls-for="integrity">
                        <div class="dd-control-group">
                            <input type="search" class="dd-issue-search" data-filter-search placeholder="Search title/type..." aria-label="Search integrity issues">
                        </div>
                        <div class="dd-control-group dd-severity-filters" role="group" aria-label="Filter by severity">
                            <button type="button" class="dd-chip is-active" data-filter-severity="all">All</button>
                            <button type="button" class="dd-chip" data-filter-severity="critical">Critical</button>
                            <button type="button" class="dd-chip" data-filter-severity="warning">Warnings</button>
                            <button type="button" class="dd-chip" data-filter-severity="info">Info</button>
                        </div>
                        <div class="dd-control-group">
                            <select class="dd-issue-sort" data-filter-sort aria-label="Sort integrity issues">
                                <option value="severity_desc">Sort: Severity</option>
                                <option value="title_asc">Title A-Z</option>
                                <option value="title_desc">Title Z-A</option>
                            </select>
                            <button type="button" class="dd-btn dd-btn-secondary dd-btn-sm" data-filter-reset>Reset</button>
                        </div>
                    </div>
                    <div class="dd-issue-list" data-issue-list="integrity">
                        {% for issue in integrityIssues %}
                            {{ macros.render_issue(issue, loop.index, 'integrity') }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tab {{ collector.getIssueCountByCategory('configuration') == 0 ? 'disabled' }}">
            <h3 class="tab-title">🔧 Configuration ({{ collector.getIssueCountByCategory('configuration') }})</h3>
            <div class="tab-content">
                {% set configurationIssues = collector.getIssuesByCategory('configuration') %}
                {% if configurationIssues is empty %}
                    <div class="empty">
                        <p>No database configuration issues detected. Your database is properly configured!</p>
                    </div>
                {% else %}
                    {% import _self as macros %}
                    <div class="dd-issue-controls" data-controls-for="configuration">
                        <div class="dd-control-group">
                            <input type="search" class="dd-issue-search" data-filter-search placeholder="Search title/type..." aria-label="Search configuration issues">
                        </div>
                        <div class="dd-control-group dd-severity-filters" role="group" aria-label="Filter by severity">
                            <button type="button" class="dd-chip is-active" data-filter-severity="all">All</button>
                            <button type="button" class="dd-chip" data-filter-severity="critical">Critical</button>
                            <button type="button" class="dd-chip" data-filter-severity="warning">Warnings</button>
                            <button type="button" class="dd-chip" data-filter-severity="info">Info</button>
                        </div>
                        <div class="dd-control-group">
                            <select class="dd-issue-sort" data-filter-sort aria-label="Sort configuration issues">
                                <option value="severity_desc">Sort: Severity</option>
                                <option value="title_asc">Title A-Z</option>
                                <option value="title_desc">Title Z-A</option>
                            </select>
                            <button type="button" class="dd-btn dd-btn-secondary dd-btn-sm" data-filter-reset>Reset</button>
                        </div>
                    </div>
                    <div class="dd-issue-list" data-issue-list="configuration">
                        {% for issue in configurationIssues %}
                            {{ macros.render_issue(issue, loop.index, 'config') }}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="tab {{ collector.timelineQueries is empty ? 'disabled' }}">
            <h3 class="tab-title">Slowest Queries</h3>
            <div class="tab-content">
                {% if collector.timelineQueries is empty %}
                    <div class="empty">
                        <p>No queries recorded.</p>
                    </div>
                {% else %}
                    {% set groupedQueries = collector.groupedQueriesByTime|slice(0, 10) %}
                    <table class="alt queries-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Count</th>
                                <th>Total Time</th>
                                <th>Avg Time</th>
                                <th>Min/Max</th>
                                <th class="dd-w-full">Query</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for i, queryGroup in groupedQueries %}
                                {# Use higher precision for small values to avoid displaying 0 #}
                                {% set totalTimeMs = queryGroup.totalTimeMs < 0.01 ? queryGroup.totalTimeMs|round(4) : queryGroup.totalTimeMs|round(2) %}
                                {% set avgTimeMs = queryGroup.avgTimeMs < 0.01 ? queryGroup.avgTimeMs|round(4) : queryGroup.avgTimeMs|round(2) %}
                                {% set maxTimeMs = queryGroup.maxTimeMs < 0.01 ? queryGroup.maxTimeMs|round(4) : queryGroup.maxTimeMs|round(2) %}
                                {% set minTimeMs = queryGroup.minTimeMs < 0.01 ? queryGroup.minTimeMs|round(4) : queryGroup.minTimeMs|round(2) %}
                                <tr>
                                    <td><strong>{{ i + 1 }}</strong></td>
                                    <td>
                                        <span class="label {{ queryGroup.count > 1 ? 'status-warning' : '' }}">
                                            {{ queryGroup.count }}x
                                        </span>
                                    </td>
                                    <td class="time-container">
                                        <span class="{{ totalTimeMs > 50 ? 'label status-error' : (totalTimeMs > 20 ? 'label status-warning' : '') }}">
                                            {{ totalTimeMs }} ms
                                        </span>
                                    </td>
                                    <td class="time-container">
                                        <span class="{{ avgTimeMs > 50 ? 'label status-error' : (avgTimeMs > 20 ? 'label status-warning' : '') }}">
                                            {{ avgTimeMs }} ms
                                        </span>
                                    </td>
                                    <td class="text-small">
                                        {{ minTimeMs }} / {{ maxTimeMs }} ms
                                    </td>
                                    <td>
                                        <div class="text-small">
                                            <button type="button" class="sf-toggle link-inverse" data-toggle-selector="#query-{{ loop.index }}" data-toggle-alt-content="Hide query" aria-controls="query-{{ loop.index }}" aria-expanded="false">
                                                View query
                                            </button>
                                        </div>
                                        <div id="query-{{ loop.index }}" class="hidden dd-mt-5">
                                            <div class="dd-fs-12">
                                                {{ queryGroup.sql|doctrine_format_sql(highlight = true)|raw }}
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>

                    {% if collector.groupedQueriesByTime|length > 10 %}
                        <div class="text-small font-normal dd-mt-20">
                            <button type="button" class="sf-toggle link-inverse" data-toggle-selector="#all-queries" data-toggle-alt-content="Hide all queries" aria-controls="all-queries" aria-expanded="false">
                                Show all grouped queries ({{ collector.groupedQueriesByTime|length }} unique)
                            </button>
                        </div>
                        <div id="all-queries" class="hidden dd-mt-10">
                            <table class="alt queries-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Count</th>
                                        <th>Total Time</th>
                                        <th>Avg Time</th>
                                        <th class="dd-w-full">Query</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for i, queryGroup in collector.groupedQueriesByTime %}
                                        {# Use higher precision for small values to avoid displaying 0 #}
                                        {% set totalTimeMs = queryGroup.totalTimeMs < 0.01 ? queryGroup.totalTimeMs|round(4) : queryGroup.totalTimeMs|round(2) %}
                                        {% set avgTimeMs = queryGroup.avgTimeMs < 0.01 ? queryGroup.avgTimeMs|round(4) : queryGroup.avgTimeMs|round(2) %}
                                        <tr>
                                            <td>{{ i + 1 }}</td>
                                            <td>{{ queryGroup.count }}x</td>
                                            <td>{{ totalTimeMs }} ms</td>
                                            <td>{{ avgTimeMs }} ms</td>
                                            <td>
                                                <div class="dd-fs-12">
                                                    {{ queryGroup.sql|doctrine_prettify_sql|raw }}
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>

        {% if collector.isDebugInfoEnabled %}
            <div class="tab">
                <h3 class="tab-title">Debug Information</h3>
                <div class="tab-content">
                    <div class="help">
                        <p><strong>Note:</strong> This debug section is only visible because <code>show_debug_info</code> is enabled in your configuration.</p>
                    </div>
                    {% set debug = collector.getDebug %}
                    <table class="alt">
                        <thead>
                            <tr>
                                <th class="dd-w-30">Metric</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <th>Debug Data Available</th>
                                <td>{{ debug is empty ? 'No' : 'Yes' }}</td>
                            </tr>
                            {% if debug is not empty %}
                                <tr>
                                    <th>Doctrine Collector Exists</th>
                                    <td>{{ debug.doctrine_collector_exists|default('N/A') ? 'Yes' : 'No' }}</td>
                                </tr>
                                <tr>
                                    <th>Analyzers Count</th>
                                    <td><strong>{{ debug.analyzers_count|default('N/A') }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Total Queries Found</th>
                                    <td><strong>{{ debug.total_queries|default('N/A') }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Timeline Queries Count</th>
                                    <td><strong>{{ collector.timelineQueries|length }}</strong></td>
                                </tr>
                                <tr>
                                    <th>Issues Count</th>
                                    <td><strong class="{{ collector.getIssues|length > 0 ? 'status-error' : 'status-success' }}">{{ collector.getIssues|length }}</strong></td>
                                </tr>
                                {% if debug.profiler_overhead_ms is defined and debug.profiler_overhead_ms > 0 %}
                                    <tr class="dd-bg-muted">
                                        <th colspan="2" class="dd-p-10 dd-bt-2-muted">
                                            <strong>Profiler Overhead (Excluded from App Performance)</strong>
                                        </th>
                                    </tr>
                                    {% set overhead = collector.getProfilerOverhead %}
                                    <tr>
                                        <th class="dd-pl-20">Query Analysis Time</th>
                                        <td><strong>{{ overhead.analysis_time_ms|number_format(2) }} ms</strong></td>
                                    </tr>
                                    <tr>
                                        <th class="dd-pl-20">Database Info Collection Time</th>
                                        <td><strong>{{ overhead.db_info_time_ms|number_format(2) }} ms</strong></td>
                                    </tr>
                                    <tr>
                                        <th class="dd-pl-20">Total Profiler Overhead</th>
                                        <td><strong class="dd-muted-strong">{{ overhead.total_time_ms|number_format(2) }} ms</strong></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2" class="dd-p-10 dd-fs-90 dd-text-muted-666 dd-bg-muted">
                                            <em>ℹ️ This time is isolated using Stopwatch with category "doctrine_doctor_profiling" and is NOT included in your application's performance metrics.</em>
                                        </td>
                                    </tr>
                                {% endif %}
                                {% if debug.analyzer_stats is defined %}
                                    <tr>
                                        <th>Analyzer Performance</th>
                                        <td>
                                            <table class="alt">
                                                <thead>
                                                    <tr>
                                                        <th>Analyzer</th>
                                                        <th>Issues Found</th>
                                                        <th>Execution Time</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {% for analyzer, stats in debug.analyzer_stats %}
                                                        <tr>
                                                            <td>{{ analyzer|split('\\\\')|last }}</td>
                                                            <td><strong>{{ stats.issues_found }}</strong></td>
                                                            <td>{{ stats.execution_time_ms }}ms</td>
                                                        </tr>
                                                    {% endfor %}
                                                </tbody>
                                            </table>
                                        </td>
                                    </tr>
                                {% endif %}
                                {% if debug.analyzer_errors is defined and debug.analyzer_errors is not empty %}
                                    <tr>
                                        <th>Analyzer Errors</th>
                                        <td>
                                            <pre class="sf-dump">{{ debug.analyzer_errors|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                                        </td>
                                    </tr>
                                {% endif %}
                            {% else %}
                                <tr>
                                    <td colspan="2"><span class="label status-error">Collector did not collect data</span></td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    <style>{% include '@DoctrineDoctor/profiler/_doctrine_doctor_panel.css.twig' %}</style>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js" data-manual></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-markup-templating.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-php.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-sql.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-yaml.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-bash.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-twig.min.js"></script>

    <script type="text/javascript">//<![CDATA[
{% include '@DoctrineDoctor/profiler/_doctrine_doctor_panel.js.twig' %}
    //]]></script>
{% endblock %}
